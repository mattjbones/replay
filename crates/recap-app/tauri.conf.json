{
  "$schema": "https://raw.githubusercontent.com/nicoe/tauri/dev/crates/tauri-utils/schema.json",
  "productName": "Recap",
  "version": "0.0.0",
  "identifier": "com.recap.desktop",
  "build": {
    "frontendDist": "../../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Recap",
        "url": "index.html",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon.icns",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/mattjbones/replay/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlGMDhEQTc2MUI5NzFCMTcKUldRWEc1Y2JkdG9JbjZHalI2dklBSEk0RTZCN3ZHQ3lCZEdrTDNTdFNuRUlhUlZGNEorS3VsMGIK"
    }
  }
}
